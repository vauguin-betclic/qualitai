# GitHub OAuth App credentials — register at https://github.com/settings/developers
# Authorization callback URL on the OAuth App must be: ${BASE_URL}/login/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# 32-byte random key used to encrypt the session cookie (AES-GCM).
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Public origin of the app. Used to build the OAuth callback URL.
BASE_URL=http://localhost:5173
